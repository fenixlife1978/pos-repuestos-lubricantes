{
  "compilerOptions": {
    "target": "ES2017",
    "module": "CommonJS",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "outDir": "./dist"
  },
  "include": [
    "main.js",
    "preload.js"
  ],
  "exclude": [
    "../node_modules",
    "./dist"
  ]
}