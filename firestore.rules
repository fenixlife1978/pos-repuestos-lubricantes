rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // FUNCIONES DE VALIDACIÓN
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Verifica si el usuario es administrador buscando su UID en la colección users
    function isAdmin() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.rol == 'administrador';
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // EL ESTADO DEL SISTEMA ES PÚBLICO PARA LECTURA (Para detectar si el sistema es nuevo)
    match /pos_system_data/state {
      allow read: if true;
      allow write: if isAdmin() || (request.resource.data.isInitialized == true);
    }

    // ADMINISTRADORES: Acceso total a todo el sistema
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // REGLAS ESPECÍFICAS PARA USUARIOS NO-ADMIN
    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      // Solo el dueño o el admin escriben, pero solo el admin cambia el rol o el bloqueo
      allow write: if isAuthenticated() && (isOwner(userId) || isAdmin());
    }

    // Colecciones operativas (Lectura/Escritura para cualquier autenticado no bloqueado)
    match /{collectionName}/{docId} {
      allow read, write: if isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.accesoBloqueado == false;
    }
  }
}